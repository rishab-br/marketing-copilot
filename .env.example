# ---- LLM provider ----
# Provider behind the thin client wrapper (app/llm/client.py).
# v1 default: groq. Keep this swappable; never hardcode model strings in logic.
LLM_PROVIDER=groq

# Model name is env-driven.
#   Groq examples:   llama-3.3-70b-versatile, llama-3.1-8b-instant
#   Gemini examples: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=llama-3.3-70b-versatile

# API key for the selected provider. Set the one matching LLM_PROVIDER.
GROQ_API_KEY=your-groq-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# Default sampling temperature for agent calls.
LLM_TEMPERATURE=0.7

# ---- Orchestration knobs ----
# Loop gate: an asset PASSES when its overall score is >= this threshold (1.0–5.0).
EVAL_THRESHOLD=4.0
# Max copywriter <-> critic revision cycles before returning best-so-far (flagged).
MAX_ITERATIONS=3

# ---- Persistence ----
# SQLite by default; swap to Postgres later without code changes.
DATABASE_URL=sqlite:///./marketing_copilot.db

# ---- App ----
LOG_LEVEL=INFO
