# ---- LLM provider ----
# Provider behind the thin client wrapper (app/llm/client.py).
# v1 default: gemini. Keep this swappable; never hardcode model strings in logic.
LLM_PROVIDER=gemini

# Model name is env-driven. Examples for Gemini: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=gemini-2.0-flash

# API key for the selected provider (Gemini = Google AI Studio key).
GEMINI_API_KEY=your-gemini-api-key-here

# Default sampling temperature for agent calls.
LLM_TEMPERATURE=0.7

# ---- Orchestration knobs ----
# Loop gate: an asset PASSES when its overall score is >= this threshold (1.0–5.0).
EVAL_THRESHOLD=4.0
# Max copywriter <-> critic revision cycles before returning best-so-far (flagged).
MAX_ITERATIONS=3

# ---- Persistence ----
# SQLite by default; swap to Postgres later without code changes.
DATABASE_URL=sqlite:///./marketing_copilot.db

# ---- App ----
LOG_LEVEL=INFO
